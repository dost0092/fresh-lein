# Supabase — create a project at https://supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe (client-side publishable key)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here


# Optional: Stripe Payment Links (works without Supabase Edge Functions)
# Create at https://dashboard.stripe.com/test/payment-links
VITE_STRIPE_PAYMENT_LINK_STARTER=https://buy.stripe.com/test_xxxxx
VITE_STRIPE_PAYMENT_LINK_PRO=https://buy.stripe.com/test_xxxxx


# ----------------------------------------------------------------------------
# FreshLien AI Assistant (server-side only — NEVER prefix with VITE_)
# These are read by the /api/assistant serverless function and are never sent
# to the browser. Set GROK_KEY in Vercel (Project Settings -> Environment Variables).
# ----------------------------------------------------------------------------
# Your OpenRouter API key (https://openrouter.ai/keys). Get one for free.
GROK_KEY=

# Optional: override the model. Defaults to x-ai/grok-4-fast:free
# Other free options: meta-llama/llama-3.3-70b-instruct:free, etc.
OPENROUTER_MODEL=x-ai/grok-4-fast:free

# Optional: used for OpenRouter referer/attribution and rankings
PUBLIC_SITE_URL=https://freshlien.com


# ----------------------------------------------------------------------------
# FreshLien CRM — multi-tenant bulk email (server-side only — NEVER use VITE_)
#
# Architecture: agents' contacts/campaigns live in Supabase (RLS per user).
# /api/crm/campaigns/send enqueues one row per recipient in crm_messages and
# returns immediately; a Vercel Cron (/api/crm/worker, see vercel.json) drains
# the queue so big sends never hit the serverless timeout.
#
# Requires the same Supabase service role used by the other /api functions:
#   SUPABASE_URL  (or VITE_SUPABASE_URL)
#   SUPABASE_SERVICE_ROLE_KEY
#
# If NEITHER email key below is set, the CRM runs in safe SIMULATION mode
# (no real emails) so you can demo and test the full flow.
# ----------------------------------------------------------------------------
# Option A — Resend (recommended, simplest): https://resend.com/api-keys
RESEND_API_KEY=

# Option B — SendGrid (alternative): https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# Multi-tenant sender (Approach A): all mail goes FROM this verified address,
# with Reply-To automatically set to the sending agent's own email.
# Verify your domain in Resend, then use e.g. agents@mail.freshlien.com.
# The Resend test default (onboarding@resend.dev) only delivers to your inbox.
CRM_FROM_EMAIL=onboarding@resend.dev
CRM_FROM_NAME=FreshLien CRM

# Protects the cron worker endpoint. Set any long random string. Vercel Cron
# automatically sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=